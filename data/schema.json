umor", "type": "object"}, "Progression": {"additionalProperties": true, "description": "Disease progression event.", "properties": {"progressiondate": {"description": "Date of progression", "format": "date", "title": "Progressiondate", "type": "string"}, "contextsentence": {"description": "Sentence supporting this information", "title": "Contextsentence", "type": "string"}}, "required": ["progressiondate", "contextsentence"], "title": "Progression", "type": "object"}, "Radiotherapy": {"additionalProperties": true, "description": "Radiotherapy treatment.", "properties": {"radiotherapytype": {"description": "Type of radiotherapy", "title": "Radiotherapytype", "type": "string"}, "radiotherapydate_first": {"description": "First radiotherapy date", "format": "date", "title": "Radiotherapydate First", "type": "string"}, "contextsentence": {"description": "Sentence supporting this information", "title": "Contextsentence", "type": "string"}}, "required": ["radiotherapytype", "radiotherapydate_first", "contextsentence"], "title": "Radiotherapy", "type": "object"}, "Surgery": {"additionalProperties": true, "description": "Surgical procedure.", "properties": {"surgerytype": {"description": "Surgery type or code", "title": "Surgerytype", "type": "string"}, "surgerydate": {"description": "Date of surgery", "format": "date", "title": "Surgerydate", "type": "string"}, "contextsentence": {"description": "Sentence supporting this information", "title": "Contextsentence", "type": "string"}}, "required": ["surgerytype", "surgerydate", "contextsentence"], "title": "Surgery", "type": "object"}, "TumorEvent": {"additionalProperties": true, "description": "Tumor-related clinical event.", "properties": {"tumeventtype": {"description": "Type of tumor event", "enum": ["Local/regional relapse or Recurrence", "Metastasis", "Transformation"], "title": "Tumeventtype", "type": "string"}, "tumeventdiagnosisdate": {"description": "Date of event diagnosis", "format": "date", "title": "Tumeventdiagno